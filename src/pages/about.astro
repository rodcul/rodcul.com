---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import Entry from "../components/Entry.astro";
import ContactLink from "../components/ContactLink.astro";

const link = "text-teal-400 hover:text-teal-300 transition";
---

<Layout
  title="About — Rodney Cullen"
  description="Born in Abu Dhabi, raised in Spain, based in San Francisco — via an engineering hub in Barcelona, a supplement brand in Mexico, and a coffee shop in Chiang Mai."
>
  <div class="flex w-full">
    <!-- Background panel -->
    <div class="fixed inset-0 flex justify-center sm:px-8">
      <div class="flex w-full max-w-7xl lg:px-8">
        <div class="w-full bg-zinc-900 ring-1 ring-white/10"></div>
      </div>
    </div>

    <div class="relative flex w-full flex-col">
      <main class="flex-auto">
        <div class="px-5 sm:px-8 mt-14 sm:mt-24">
          <div class="mx-auto w-full max-w-2xl lg:max-w-3xl">
            <!-- Back link -->
            <a
              href="/"
              class="inline-flex items-center gap-1 text-sm text-zinc-300 transition hover:text-teal-400"
            >
              ← rodcul.com
            </a>

            <!-- Header / identity -->
            <header class="mt-8">
              <div class="flex items-center gap-4 sm:gap-5">
                <img
                  alt="Rodney Cullen"
                  width="160"
                  height="160"
                  class="h-16 w-16 flex-none rounded-2xl object-cover ring-1 ring-white/15 sm:h-20 sm:w-20"
                  src="/img/portrait.jpeg"
                />
                <div>
                  <p class="text-lg font-semibold text-white sm:text-xl">
                    Rodney Cullen
                  </p>
                  <p class="mt-0.5 text-sm text-teal-400">
                    Growth Engineer · San Francisco
                  </p>
                </div>
              </div>

              <h1
                class="mt-8 text-3xl font-bold tracking-tight text-white sm:mt-10 sm:text-4xl"
              >
                From Abu Dhabi to San Francisco — via Barcelona, Mexico, and a
                coffee shop in Chiang Mai.
              </h1>

              <div class="mt-6 space-y-5 text-base leading-relaxed text-zinc-300 sm:text-lg">
                <p>
                  I was born in Abu Dhabi and raised in Spain, so I grew up
                  bilingual (English/Spanish) and comfortable being the new guy
                  in the room. That turned into a career of dropping into
                  unfamiliar situations and making things work: launching an
                  engineering hub in Barcelona, scaling SEO traffic from 8K to
                  300K visits a day, and founding a supplement brand that I ran
                  end to end across Shopify, Amazon, and MercadoLibre in
                  Mexico.
                </p>
                <p>
                  In between, I bought and ran
                  <a
                    href="https://www.instagram.com/overstandcoffee/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class={link}>Overstand</a
                  >, a coffee shop in Chiang Mai, Thailand, for two years —
                  hiring, operations, and finances, hands-on. I've also been
                  part of a 3-person team that built a 90-person Burning Man
                  camp: 17 hexayurts, 6,000 sq ft of shade, swamp coolers, a
                  kitchen, 90 bikes, and a 110v + 12v power grid in the desert.
                </p>
                <p>
                  Most recently I was Chief of Staff at HF0, an SF startup
                  residency, working side-by-side with the CEO to turn vision
                  into execution. These days I work as an independent growth
                  engineer, embedded with founders at early-stage San Francisco
                  startups — the
                  <a href="/" class={link}>work lives here</a>.
                </p>
              </div>
            </header>

            <!-- Condensed roles -->
            <Section id="roles" title="Roles">
              <Entry title="">
                <Fragment slot="title">
                  Chief of Staff at <a
                    href="https://www.linkedin.com/company/hf0/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class={link}>HF0</a
                  >
                </Fragment>
                Managed day-to-day priorities with the CEO, created structure,
                and scaled up a fast-moving tech residency.
              </Entry>
              <Entry title="Independent Growth Engineer">
                Embedded with founders at early-stage SF startups — funnels,
                conversion tracking, and growth tooling for teams running
                six-figure/month ad spend.
              </Entry>
              <Entry title="Founder & Ecommerce Operator">
                Founded and operated a supplement brand across Shopify, Amazon,
                and MercadoLibre (MX) — acquisition, conversion, retention, and
                operations end to end.
              </Entry>
              <Entry title="">
                <Fragment slot="title">
                  Engineering Hub Lead at <a
                    href="https://www.linkedin.com/company/kodify/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class={link}>Kodify</a
                  >
                </Fragment>
                Launched an engineering hub in Barcelona — recruited the team
                and shipped a platform rebuild in under 90 days.
              </Entry>
            </Section>

            <!-- Contact footer -->
            <section
              class="mt-16 border-t border-zinc-800 pt-10"
              aria-labelledby="contact"
            >
              <h2 id="contact" class="font-semibold text-white">Contact</h2>
              <ul role="list" class="mt-6 space-y-4">
                <ContactLink href="#" data-eu="rodcul" data-ed="gmail.com" label="Email me">
                  <path
                    fill-rule="evenodd"
                    d="M6 5a3 3 0 0 0-3 3v8a3 3 0 0 0 3 3h12a3 3 0 0 0 3-3V8a3 3 0 0 0-3-3H6Zm.245 2.187a.75.75 0 0 0-.99 1.126l6.25 5.5a.75.75 0 0 0 .99 0l6.25-5.5a.75.75 0 0 0-.99-1.126L12 12.251 6.245 7.187Z"
                  ></path>
                </ContactLink>
                <ContactLink
                  href="https://wa.me/13102275317"
                  label="WhatsApp"
                  external
                >
                  <path
                    fill-rule="evenodd"
                    d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z"
                    clip-rule="evenodd"></path>
                </ContactLink>
                <ContactLink
                  href="https://www.linkedin.com/in/rodcul"
                  label="LinkedIn"
                  external
                >
                  <path
                    d="M18.335 18.339H15.67v-4.177c0-.996-.02-2.278-1.39-2.278-1.389 0-1.601 1.084-1.601 2.205v4.25h-2.666V9.75h2.56v1.17h.035c.358-.674 1.228-1.387 2.528-1.387 2.7 0 3.2 1.778 3.2 4.091v4.715zM7.003 8.575a1.546 1.546 0 01-1.548-1.549 1.548 1.548 0 111.547 1.549zm1.336 9.764H5.666V9.75H8.34v8.589zM19.67 3H4.329C3.593 3 3 3.58 3 4.297v15.406C3 20.42 3.594 21 4.328 21h15.338C20.4 21 21 20.42 21 19.703V4.297C21 3.58 20.4 3 19.666 3h.003z"
                  ></path>
                </ContactLink>
                <ContactLink href="https://x.com/rodcul" label="X/Twitter" external>
                  <path
                    d="M13.3174 10.7749L19.1457 4H17.7646L12.7039 9.88256L8.66193 4H4L10.1122 12.8955L4 20H5.38119L10.7254 13.7878L14.994 20H19.656L13.3171 10.7749H13.3174ZM11.4257 12.9738L10.8064 12.0881L5.87886 5.03974H8.00029L11.9769 10.728L12.5962 11.6137L17.7652 19.0075H15.6438L11.4257 12.9742V12.9738Z"
                  ></path>
                </ContactLink>
              </ul>
            </section>
          </div>
        </div>
      </main>

      <div class="extra-bottom-padding"></div>
    </div>
  </div>

  <script>
    // Assemble mailto links client-side so the address never appears in the HTML.
    document.querySelectorAll<HTMLAnchorElement>("a[data-eu]").forEach((a) => {
      a.href = "mailto:" + a.dataset.eu + "@" + a.dataset.ed;
    });
  </script>
</Layout>
